<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingVertical="24dp">

        <dev.oneuiproject.oneui.widget.SwitchItemView
            android:id="@+id/actionModeShowCancel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:showTopDivider="false"
            app:title="@string/show_cancel_button" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginVertical="16dp"
            android:orientation="horizontal"
            android:paddingHorizontal="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/index_scroll"
                android:textColor="?android:textColorSecondaryInverseNoDisable"
                android:textStyle="bold" />

            <ImageView
                android:layout_width="0dp"
                android:layout_height="5dp"
                android:layout_gravity="center_vertical"
                android:layout_marginHorizontal="12dp"
                android:layout_weight="1"
                android:clickable="false"
                android:focusable="false"
                android:src="@drawable/drawer_item_separator_bg"
                tools:ignore="ContentDescription" />

        </LinearLayout>

        <dev.oneuiproject.oneui.widget.SwitchItemView
            android:id="@+id/showIndexScroll"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:showTopDivider="false"
            app:title="@string/show_index_scroll" />

        <dev.oneuiproject.oneui.widget.SwitchItemView
            android:id="@+id/indexScrollShowLetters"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:showTopDivider="false"
            app:title="@string/show_letters" />

        <dev.oneuiproject.oneui.widget.SwitchItemView
            android:id="@+id/indexScrollAutoHide"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:showTopDivider="false"
            app:title="@string/auto_hide" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginVertical="16dp"
            android:orientation="horizontal"
            android:paddingHorizontal="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/action_mode_search_options"
                android:textColor="?android:textColorSecondaryInverseNoDisable"
                android:textStyle="bold" />

            <ImageView
                android:layout_width="0dp"
                android:layout_height="5dp"
                android:layout_gravity="center_vertical"
                android:layout_marginHorizontal="12dp"
                android:layout_weight="1"
                android:clickable="false"
                android:focusable="false"
                android:src="@drawable/drawer_item_separator_bg"
                tools:ignore="ContentDescription" />

        </LinearLayout>

        <dev.oneuiproject.oneui.widget.RadioItemViewGroup
            android:id="@+id/amsOptions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <dev.oneuiproject.oneui.widget.RadioItemView
                android:id="@+id/amsDismiss"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:title="DISMISS" />

            <dev.oneuiproject.oneui.widget.RadioItemView
                android:id="@+id/amsNoDismiss"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:title="NO_DISMISS" />

            <dev.oneuiproject.oneui.widget.RadioItemView
                android:id="@+id/amsConcurrent"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:title="CONCURRENT" />
        </dev.oneuiproject.oneui.widget.RadioItemViewGroup>

    </LinearLayout>


</androidx.core.widget.NestedScrollView>
