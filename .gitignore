# .idea/ — whitelist: ignore all, allow only project-required files
/.idea/*
!/.idea/.gitignore
!/.idea/.name
!/.idea/icon.png
!/.idea/AndroidProjectSystem.xml
!/.idea/codeStyles/
!/.idea/codeStyles/**
!/.idea/compiler.xml
!/.idea/inspectionProfiles/
!/.idea/inspectionProfiles/**
!/.idea/jarRepositories.xml
!/.idea/kotlinc.xml
!/.idea/ktlint-plugin.xml
!/.idea/misc.xml
!/.idea/vcs.xml

*.iml
.gradle
.DS_Store
.kotlin/

build/
*.aab

/captures
.externalNativeBuild
.cxx

# Credentials / local config
local.properties
keystore.properties
github.properties
google-services.json
*.jks
*.keystore
*.p12
