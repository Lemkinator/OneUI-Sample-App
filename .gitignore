# .idea/ — ignore contents, whitelist only what the project needs
/.idea/*
!/.idea/.gitignore
!/.idea/.name
!/.idea/icon.png
!/.idea/AndroidProjectSystem.xml
!/.idea/codeStyles/
!/.idea/codeStyles/**
!/.idea/compiler.xml
!/.idea/inspectionProfiles/
!/.idea/inspectionProfiles/**
!/.idea/jarRepositories.xml
!/.idea/kotlinc.xml
!/.idea/ktlint-plugin.xml
!/.idea/vcs.xml
!/.idea/runConfigurations/
!/.idea/runConfigurations/**

*.iml
.gradle
.DS_Store
.kotlin/

build/
*.aab

/captures
.externalNativeBuild
.cxx

local.properties
keystore.properties
github.properties

*.jks
